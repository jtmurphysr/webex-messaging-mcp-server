# Webex MCP Server Configuration
# Copy this file to .env and fill in your actual values

# Authentication Mode Options (choose one):

# Option 1: OAuth2 Integration (Recommended for long-term use)
# Register an Integration at developer.webex.com with required scopes
# Then run: npm run auth:setup
WEBEX_CLIENT_ID=your-integration-client-id
WEBEX_CLIENT_SECRET=your-integration-client-secret

# Option 2: Bot Token (For bot-scoped operations)
# Create a bot at developer.webex.com and get the bot token
WEBEX_BOT_TOKEN=your-bot-token-here

# Option 3: Bearer Token (Legacy, 12-hour expiry)
# Get your token from: https://developer.webex.com
# Note: Tokens expire every 12 hours and need renewal
WEBEX_PUBLIC_WORKSPACE_API_KEY=your-webex-api-token-here

# Optional: Explicit auth mode (oauth|bearer|bot)
# If not set, auto-detection uses priority: OAuth > Bot > Bearer
WEBEX_AUTH_MODE=

# Optional: Webex API Base URL (defaults to https://webexapis.com/v1)
# Only change this if you're using a different Webex environment
WEBEX_API_BASE_URL=https://webexapis.com/v1

# User Information (for reference)
WEBEX_USER_EMAIL=your-email@company.com

# Optional: Server Mode (defaults to STDIO)
# Set to 'http' for HTTP mode, 'sse' for SSE mode, or leave blank for STDIO
MCP_MODE=

# Optional: Port for HTTP/SSE mode (defaults to 3001)
# Only used when running with --http or --sse flag
PORT=3001

# Optional: Custom path for token storage (defaults to ~/.webex-mcp/tokens.json)
# Override the default location where OAuth tokens are stored
# Example: /custom/path/tokens.json
WEBEX_TOKEN_STORE_PATH=
